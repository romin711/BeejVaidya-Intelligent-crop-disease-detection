# -----------------------------
# Python bytecode and caches
# -----------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# -----------------------------
# Virtual environments
# -----------------------------
venv/
.venv/
env/
ENV/
venv_new/
venv_tf/
venv_old/

# -----------------------------
# Build / packaging
# -----------------------------
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# -----------------------------
# Test / lint / type-check caches
# -----------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.pyre/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# -----------------------------
# Logs and runtime files
# -----------------------------
*.log
logs/*.log
logs/*.csv
*.pid
*.pid.lock

# -----------------------------
# Environment and local settings
# -----------------------------
.env
.env.*
*.env
!.env.example
.python-version

# -----------------------------
# Machine learning artifacts
# -----------------------------
models/*.h5
models/*.keras
models/*.ckpt
models/*.pb
models/*.tflite

# TensorBoard / experiment tracking
runs/
wandb/
mlruns/

# -----------------------------
# Dataset and generated results
# -----------------------------
dataset/raw/
dataset/processed/
dataset/split/
results/logs/
results/reports/

# Keep folder placeholders if used
!dataset/**/.gitkeep
!results/**/.gitkeep

# -----------------------------
# Jupyter
# -----------------------------
.ipynb_checkpoints/

# -----------------------------
# Frontend / JS (if added later)
# -----------------------------
node_modules/
.npm/
.pnpm-store/

# -----------------------------
# IDE / Editor
# -----------------------------
.vscode/
.idea/
*.iml
.codex

# -----------------------------
# OS files
# -----------------------------
.DS_Store
Thumbs.db
Desktop.ini
